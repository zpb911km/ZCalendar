{
  "packageFiles": [
    "package.json",
    "src-tauri/Cargo.toml",
    "src-tauri/tauri.conf.json"
  ],
  "bumpFiles": [
    "package.json",
    "src-tauri/Cargo.toml",
    "src-tauri/tauri.conf.json"
  ],
  "types": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "chore",
      "hidden": true
    },
    {
      "type": "docs",
      "hidden": true
    },
    {
      "type": "style",
      "hidden": true
    },
    {
      "type": "refactor",
      "hidden": true
    },
    {
      "type": "perf",
      "hidden": true
    },
    {
      "type": "test",
      "hidden": true
    }
  ],
  "commitAll": false,
  "tagPrefix": "v",
  "scripts": {
    "posttag": "git push --follow-tags origin main"
  }
}
